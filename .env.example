# AI Personal Assistant — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit real secrets to version control.

# Anthropic (Claude) — primary AI for classification and extraction
ANTHROPIC_API_KEY=

# OpenAI — Whisper transcription + fallback classifier + embeddings (future)
OPENAI_API_KEY=

# Supabase — database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram — capture bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Development security guard (Phases 4–15)
# Required on all non-webhook backend routes. Replaced by real auth in Phase 15.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DEV_ADMIN_TOKEN=
