# AI Personal Assistant — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit real secrets to version control.

# Anthropic (Claude) — reserved for possible future capabilities; not required by Phase 6
ANTHROPIC_API_KEY=

# OpenAI — approved primary API for Phase 6 text classification (gpt-4o-mini)
# and Phase 10 voice transcription (Whisper)
# Required for AI classification. If absent, captures land as item_type="unknown" stubs.
OPENAI_API_KEY=

# Supabase — database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OWNER_USER_ID=                               # backend only: owner UID from Authentication -> Users

# Telegram — capture bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USER_ID=

# Timezone — used for daily rollover logic (Phase 10+, e.g. Asia/Singapore)
USER_TIMEZONE=

# Frontend → backend URL (local dev; frontend reads this at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=                    # public-safe Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=               # public-safe anon key; RLS denies direct data access

# Brokers — read-only portfolio (Phase 14). Backend-only. NEVER expose to the frontend and
# never use a NEXT_PUBLIC_ prefix. Do not commit the private key file.

# IBKR — Client Portal Web API. Requires the Client Portal Gateway running locally and an
# authenticated browser SSO session. Adapter is strictly GET-only (read-only).
IBKR_ENABLED=                                   # "true" to enable; otherwise reports not_configured
IBKR_CPAPI_BASE_URL=https://localhost:5000/v1/api
IBKR_CPAPI_CACERT=                              # optional path to the gateway cert/CA bundle; if set, TLS is verified
IBKR_ACCOUNT_LABEL=                            # optional friendly label; otherwise the account is masked

# Tiger Brokers OpenAPI (tigeropen). Configure ONE of the two ways below.
#
# Preferred: point at the directory holding Tiger's tiger_openapi_config.properties file
# (contains private_key_pk1, tiger_id, account, license, env). The SDK loads it all; nothing
# to extract. Keep the folder OUTSIDE the repo and never commit it. Takes precedence.
TIGER_PROPS_PATH=                               # e.g. C:\path\to\secrets\tiger_config
#
# Explicit alternative (only used if TIGER_PROPS_PATH is unset). Private key must be PKCS#1.
TIGER_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY_PATH=                         # path to the PKCS#1 private key file (never commit the key)
TIGER_ACCOUNT_LABEL=                            # optional friendly label; otherwise the account is masked

# Per-broker fetch timeout in seconds for GET /portfolio (default 8).
PORTFOLIO_BROKER_TIMEOUT=8

# --- Production (Phase 16: Render backend / Vercel frontend) ---
# Backend (Render env vars): SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#   OWNER_USER_ID, OPENAI_API_KEY, TELEGRAM_BOT_TOKEN, TELEGRAM_WEBHOOK_SECRET,
#   TELEGRAM_USER_ID, USER_TIMEZONE, PORTFOLIO_BROKER_TIMEOUT, and TIGER_PROPS_PATH pointed at
#   a Render Secret File directory (upload the Tiger config there).
#   Do NOT set IBKR_* in production (the Client Portal Gateway can't run on a PaaS).
#   Do NOT set DEV_ADMIN_TOKEN (removed in Phase 15a).
# Frontend (Vercel env vars): NEXT_PUBLIC_API_URL=<render backend url>, plus the two
#   NEXT_PUBLIC_SUPABASE_* values above (public-safe).
